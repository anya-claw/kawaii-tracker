{
    "compilerOptions": {
        "target": "ES2022",
        "types": ["node", "better-sqlite3"],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "strict": true,
        "ignoreDeprecations": "5.0",
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": ["src/**/*"]
}
